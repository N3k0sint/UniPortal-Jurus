# Flask Settings
SECRET_KEY=generate_a_random_secure_hex_key_here
FLASK_ENV=production
FLASK_DEBUG=False

# Database configuration
# For local development, Flask will default to SQLite if DATABASE_URL is not provided or set to sqlite:///local.db
# For production PostgreSQL: postgresql://username:password@localhost/dbname
DATABASE_URL=postgresql://portal_user:secure_password_here@localhost/uniklpj_db

# File Upload Settings
# Limit upload directory and size (max 10MB in code)
# In production, this should be outside the web root (e.g. /var/www/uniklpj_uploads/)
UPLOAD_FOLDER=/var/www/uniklpj_uploads/
